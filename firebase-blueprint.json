{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User account information and roles.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["operator", "leader", "mechanic", "manager"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Forklift": {
      "title": "Machine",
      "description": "Machine data and status.",
      "type": "object",
      "properties": {
        "model": { "type": "string" },
        "serialNumber": { "type": "string" },
        "type": { "type": "string", "enum": ["empilhadeira", "manipulador"] },
        "status": { "type": "string", "enum": ["available", "stopped", "maintenance", "at_risk"] },
        "lastHourMeter": { "type": "number" },
        "lastHourMeterUpdate": { "type": "string", "format": "date-time" }
      }
    },
    "OperationalEvent": {
      "title": "Operational Event",
      "description": "Log of machine activities and production.",
      "type": "object",
      "properties": {
        "forkliftId": { "type": "string" },
        "operatorIds": { "type": "array", "items": { "type": "string" } },
        "operationType": { "type": "string" },
        "action": { "type": "string" },
        "production": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" },
        "shift": { "type": "string", "enum": ["1", "2"] }
      }
    },
    "MaintenanceStop": {
      "title": "Maintenance Record",
      "description": "Information about machine maintenance and repairs.",
      "type": "object",
      "properties": {
        "forkliftId": { "type": "string" },
        "status": { "type": "string" },
        "type": { "type": "string" },
        "stopTime": { "type": "string" }
      }
    },
    "InventoryPart": {
      "title": "Inventory Part",
      "description": "Parts stock information.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "quantity": { "type": "number" },
        "minQuantity": { "type": "number" }
      }
    },
    "OperatorAbsence": {
      "title": "Operator Absence",
      "description": "Information about operator leaves, vacations, or absences.",
      "type": "object",
      "properties": {
        "operatorId": { "type": "string" },
        "operatorName": { "type": "string" },
        "startDate": { "type": "string", "format": "date" },
        "endDate": { "type": "string", "format": "date" },
        "reason": { "type": "string" },
        "notes": { "type": "string" }
      },
      "required": ["operatorId", "startDate", "endDate", "reason"]
    },
    "SafraPeriod": {
      "title": "Safra Period",
      "description": "Definition of safra and entressafra periods.",
      "type": "object",
      "properties": {
        "year": { "type": "number" },
        "startDate": { "type": "string", "format": "date" },
        "endDate": { "type": "string", "format": "date" },
        "type": { "type": "string", "enum": ["safra", "entressafra"] },
        "isActive": { "type": "boolean" }
      },
      "required": ["year", "startDate", "endDate", "type", "isActive"]
    },
    "Checklist": {
      "title": "Checklist",
      "description": "Pre-operation machine safety checklist.",
      "type": "object",
      "properties": {
        "forkliftId": { "type": "string" },
        "operatorId": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "items": { "type": "object" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles."
    },
    "/forklifts/{forkliftId}": {
      "schema": "Forklift",
      "description": "Fleet machines."
    },
    "/operational_events/{eventId}": {
      "schema": "OperationalEvent",
      "description": "Activity logs."
    },
    "/maintenance/{recordId}": {
      "schema": "MaintenanceStop",
      "description": "Maintenance history."
    },
    "/parts_inventory/{partId}": {
      "schema": "InventoryPart",
      "description": "Spare parts stock."
    },
    "/operator_absences/{absenceId}": {
      "schema": "OperatorAbsence",
      "description": "Operator absence records."
    },
    "/safra_periods/{periodId}": {
      "schema": "SafraPeriod",
      "description": "Safra and entressafra periods."
    },
    "/checklists/{checklistId}": {
      "schema": "Checklist",
      "description": "Machine checklists."
    },
    "/operation_goals/{goalId}": {
      "schema": "object",
      "description": "Production goals."
    }
  }
}
